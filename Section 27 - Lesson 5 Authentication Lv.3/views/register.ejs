<%- include('partials/header') %>
<div class="container mt-5">
  <h1 class="text-center mb-4">Register</h1>
  <div class="row">
    <div class="col-md-7">
      <div class="card jumbotron mt-0">
        <div class="card-body">
          <form action="/register" method="POST">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" class="form-control" name="username">
            </div>
            <div class="form-group">
              <label for="password">Password</label>
              <input type="password" class="form-control" name="password">
            </div>
            <button type="submit" class="btn btn-dark mt-3">Register</button>
          </form>
        </div>
      </div>
    </div>
    <div class="col-md-5">
      <div class="card mt-0 d-flex align-items-center justify-content-center" style="height: 100%; border: none;">
        <div class="card-body w-100 px-2 d-flex align-items-center justify-content-center">
          <a class="google-box" href="/auth/google">
            <strong>G</strong> Sign Up with Google
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>